# replace with your Traefik dashboard domain
TRAEFIK_DOMAIN=traefik.yourdomain.com
# replace with the output of `printf "your_username:%s\n" "$(openssl passwd -apr1 'your-strong-password')"`
TRAEFIK_AUTH=user:hashed_password
# replace with your email for ACME notifications
ACME_EMAIL=your@email.com
